# App
NODE_ENV=production
APP_URL=https://jurisso.fr
APP_SECRET=changeme_32chars_minimum_random_string

# Database PostgreSQL (VPS distant)
DATABASE_URL=postgresql://dbuser:dbpassword@92.112.193.139:5444/dbname

# Redis (VPS distant)
REDIS_HOST=your-vps-ip
REDIS_PORT=6379
REDIS_PASSWORD=strong_redis_password
REDIS_TLS=true

# JWT
JWT_SECRET=changeme_64chars_minimum_ultra_random
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7

# 2FA
TWO_FA_ENCRYPTION_KEY=changeme_32chars_aes256_key

# Légifrance API (PISTE)
LEGIFRANCE_CLIENT_ID=your_client_id
LEGIFRANCE_CLIENT_SECRET=your_client_secret
LEGIFRANCE_API_URL=https://api.piste.gouv.fr

# Email (Nodemailer SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=noreply@jurisso.fr
EMAIL_FROM_NAME=JURISSO

# Stripe (paiements)
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_ENTERPRISE_PRICE_ID=price_xxx

# Frontend
NEXT_PUBLIC_API_URL=https://api.jurisso.fr

# Encryption
AES_KEY=changeme_32_char_aes_encryption_key
